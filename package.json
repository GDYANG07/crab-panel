{
  "name": "crab-panel",
  "version": "0.1.0",
  "description": "OpenClaw AI Agent 框架的中文可视化管理面板",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" --names \"server,client\" --prefix-colors \"blue,green\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "npm run build --workspaces",
    "start": "cd server && npm run start",
    "lint": "npm run lint --workspaces",
    "install:all": "npm install",
    "docker:build": "docker build -t crab-panel .",
    "docker:run": "docker run -p 3000:3000 --network host -v ~/.openclaw:/root/.openclaw:ro crab-panel",
    "docker:compose": "docker-compose up -d"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0"
  }
}
